<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="paperformat_export_a4" model="report.paperformat">
        <field name="name">Export Invoice A4 Clean</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
    </record>

    <record id="action_export_invoice_report" model="ir.actions.report">
        <field name="name">Export Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.export_invoice_template</field>
        <field name="report_file">export_docs.export_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="export_invoice_template" t-name="export_docs.export_invoice_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                
                <t t-set="buyer_orders" t-value="[]" />
                <t t-foreach="o.invoice_line_ids" t-as="l">
                    <t t-foreach="l.sale_line_ids" t-as="sl">
                        <t t-if="sl.order_id and sl.order_id.buyer_order_no">
                            <t t-if="sl.order_id.buyer_order_no not in buyer_orders">
                                <t t-set="buyer_orders" t-value="buyer_orders + [sl.order_id.buyer_order_no]" />
                            </t>
                        </t>
                    </t>
                </t>

                <t t-set="wiz" t-value="o._context.get('wizard_data', {})" />
                <t t-set="selected_ids" t-value="wiz.get('selected_line_ids', [])"/>
                <t t-set="is_lut" t-value="o.fiscal_position_id and o.fiscal_position_id.name == 'Export - LUT (WOP)'"/>

                <t t-set="inv_to_company_rate" t-value="o.currency_id._get_conversion_rate(o.currency_id, o.company_id.currency_id, o.company_id, o.invoice_date or o.date) or 0.0" />

                <t t-set="insurance_total" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service' and 'insurance' in (l.product_id.name or '').lower()).mapped('price_subtotal')) or 0.0" />
                <t t-set="freight_total" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service' and 'freight' in (l.product_id.name or '').lower()).mapped('price_subtotal')) or 0.0" />
                <t t-set="discount_amount" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service').mapped(lambda l: (l.quantity * l.price_unit * l.discount) / 100)) or 0.0" />
                <t t-set="product_total" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service').mapped('price_subtotal')) or 0.0" />

                <t t-set="net_amount" t-value="product_total" />
                <t t-set="net_cf" t-value="net_amount + freight_total" />
                <t t-set="net_cif" t-value="net_cf + insurance_total" />

                <div class="page" style="font-size:12px;">
                    <style>
                        table.item-table { width: 100%; border-collapse: collapse; border: 1px solid #000; }
                        table.item-table th { border: 1px solid #000; padding: 6px; font-weight: bold; text-align: center; background: #f2f2f2; }
                        body, table, td, th { font-family:Times New Roman, serif; font-size: 16px; border-collapse: collapse; }
                        .title { font-size: 25px; font-weight: bold; text-align: center; }
                        .item-table td { padding: 4px; vertical-align: top; border-left: 1px solid #000; border-right: 1px solid #000; border-bottom: none; border-top: none; }
                        table { width: 100%; }
                        th, td { border: 1px solid #000; padding: 6px; vertical-align: top; }
                        .no-border td { border: none; }
                        .text-right { text-align: right; }
                        .text-center { text-align: center; }
                    </style>

                    <div class="title">EXPORT INVOICE</div>

                    <table>
                        <tr>
                            <td width="60%" style="vertical-align:top;">
                                <strong>Exporter</strong><br />
                                <table width="100%" style="border:none;">
                                    <tr>
                                        <td width="25%" style="vertical-align:top; border:none;">
                                            <t t-if="o.company_id.logo"><img t-att-src="image_data_uri(o.company_id.logo)" style="max-height:80px; max-width:120px;" /></t>
                                        </td>
                                        <td width="75%" style="vertical-align:top; border:none;">
                                            <strong><t t-esc="o.company_id.name" /></strong><br />
                                            <t t-esc="o.company_id.street" /><br />
                                            <t t-esc="o.company_id.city" />, <t t-esc="o.company_id.country_id.name" /><br />
                                            <strong>GSTIN :</strong> <t t-esc="o.company_id.vat" />
                                        </td>
                                    </tr>
                                </table>
                            </td>
                            <td width="40%">
                                <strong>Invoice No :</strong> <t t-esc="o.name" /><br />
                                <strong>Date :</strong> <t t-esc="o.invoice_date" /><br />
                                <strong>Exporter Ref :</strong> <t t-esc="o.exporter_reference" /><br />
                                <strong>Buyer Order No :</strong> 
                                <t t-if="buyer_orders"><t t-esc="' / '.join(buyer_orders)" /></t>
                            </td>
                        </tr>
                    </table>

                    <table>
                        <tr>
                            <td width="50%"><strong>Consignee</strong><br /><t t-esc="o.consignee_id.name" /><br /><t t-esc="o.consignee_id.street" /><br /><t t-esc="o.consignee_id.city" />, <t t-esc="o.consignee_id.country_id.name" /></td>
                            <td width="50%"><strong>Buyer (if other than consignee)</strong><br /><t t-esc="o.buyer_id.name" /></td>
                        </tr>
                    </table>

                    <table>
                        <tr>
                            <td>Country of Origin<br /><strong><t t-esc="o.country_origin_id.name" /></strong></td>
                            <td>Final Destination<br /><strong><t t-esc="o.country_destination_id.name" /></strong></td>
                        </tr>
                        <tr>
                            <td>Pre-Carriage By<br /><strong><t t-esc="o.pre_carriage_by" /></strong></td>
                            <td>Place of Receipt<br /><strong><t t-esc="o.place_of_receipt" /></strong></td>
                        </tr>
                        <tr>
                            <td>Port of Loading<br /><strong><t t-esc="o.port_loading" /></strong></td>
                            <td>Port of Discharge<br /><strong><t t-esc="o.port_discharge" /></strong></td>
                        </tr>
                    </table>

                    <t t-set="grouped_lines" t-value="{}" />
                    <t t-foreach="o.invoice_line_ids" t-as="line">
                        <t t-if="(not selected_ids or line.id in selected_ids) and line.product_id and line.product_id.type != 'service'">
                            <t t-set="bo" t-value="(line.sale_line_ids and line.sale_line_ids[0].order_id and line.sale_line_ids[0].order_id.buyer_order_no) or 'NO BUYER ORDER'" />
                            <t t-set="current" t-value="grouped_lines.get(bo, [])" />
                            <t t-set="grouped_lines" t-value="dict(grouped_lines, **{bo: current + [line]})" />
                        </t>
                    </t>

                    <table class="item-table">
                        <thead>
                            <tr>
                                <th width="5%">Sr</th>
                                <th width="20%">Item Ref</th>
                                <th width="35%">Description</th>
                                <th>HSN</th>
                                <th width="10%">Qty</th>
                                <th width="15%">Rate (<t t-esc="o.currency_id.name" />)</th>
                                <th width="15%">Amount (<t t-esc="o.currency_id.name" />)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sr" t-value="1" />
                            <t t-foreach="grouped_lines.items()" t-as="grp">
                                <tr style="background:#f2f2f2; font-weight:bold;">
                                    <td colspan="7">Buyer Order No : <t t-esc="grp[0]"/></td>
                                </tr>
                                <t t-foreach="grp[1]" t-as="line">
                                    <tr>
                                        <td class="text-center"><t t-esc="sr" /></td>
                                        <td><t t-esc="line.product_id.default_code or ''" /></td>
                                        <td><t t-esc="line.name" /></td>
                                        <td align="right"><t t-esc="line.product_id.l10n_in_hsn_code or ''" /></td>
                                        <td class="text-right"><t t-esc="line.quantity" /></td>
                                        <td class="text-right"><t t-esc="line.price_unit" /></td>
                                        <td class="text-right"><t t-esc="line.price_subtotal" /></td>
                                    </tr>
                                    <t t-set="sr" t-value="sr + 1" />
                                </t>
                            </t>
                            <t t-foreach="range(5)" t-as="i"><tr style="height:30px;"><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr></t>
                        </tbody>
                    </table>

                    <t t-set="amount_for_words" t-value="o.amount_total" />

                    <table>
                        <tr>
                            <td width="60%">
                                <strong>Amount in Words</strong><br />
                                <em><t t-esc="o.currency_id.name"/> <t t-esc="o.currency_id.amount_to_text(amount_for_words or 0.0)" /> Only</em>
                            </td>
                            <td width="40%" style="padding:0;">
                                <table class="no-border" style="width:100%;">
                                    <tr>
                                        <td>TOTAL GOODS VALUE</td>
                                        <td class="text-right"><t t-esc="round(product_total + discount_amount, 2)" /></td>
                                    </tr>
                                    <tr t-if="discount_amount > 0">
                                        <td>LESS: DISCOUNT</td>
                                        <td class="text-right">- <t t-esc="round(discount_amount, 2)" /></td>
                                    </tr>
                                    <tr style="border-top:1px solid #000;">
                                        <td><strong>TOTAL AMOUNT</strong></td>
                                        <td class="text-right"><strong><t t-esc="round(product_total, 2)" /></strong></td>
                                    </tr>
                                    <tr>
                                        <td>ADD: FREIGHT</td>
                                        <td class="text-right"><t t-esc="round(freight_total, 2)" /></td>
                                    </tr>
                                    <tr>
                                        <td>ADD: INSURANCE</td>
                                        <td class="text-right"><t t-esc="round(insurance_total, 2)" /></td>
                                    </tr>
                                    <tr t-if="wiz.get('show_net_cf')">
                                        <td><strong>NET C&amp;F</strong></td>
                                        <td class="text-right"><strong><t t-esc="round(net_cf, 2)" /></strong></td>
                                    </tr>
                                    <tr t-if="wiz.get('show_net_cif')">
                                        <td><strong>NET CIF</strong></td>
                                        <td class="text-right"><strong><t t-esc="round(net_cif, 2)" /></strong></td>
                                    </tr>
                                    <tr style="background:#f2f2f2; border-top:2px solid #000;">
                                        <td><strong>GRAND TOTAL</strong></td>
                                        <td class="text-right"><strong><t t-esc="o.currency_id.format(o.amount_total)" /></strong></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <table>
                        <tr>
                            <td width="33%"><strong>Net Weight (Kgs)</strong><br /><t t-esc="round(o.net_weight or 0.0, 3)" /></td>
                            <td width="33%"><strong>Gross Weight (Kgs)</strong><br /><t t-esc="round(o.gross_weight or 0.0, 3)" /></td>
                            <td width="34%"><strong>Total Packages</strong><br /><t t-esc="o.total_packages or 0" /></td>
                        </tr>
                    </table>

                    <table>
                        <tr>
                            <td width="67%"><strong>Declaration :</strong><br /> We declare that this invoice shows the actual price of the goods described.</td>
                            <td class="text-right" width="33%"> For <strong><t t-esc="o.company_id.name" /></strong><br /><br /> Authorised Signatory </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
