<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="paperformat_export_a4" model="report.paperformat">
        <field name="name">Export Invoice A4 Clean</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
    </record>

    <record id="action_export_invoice_report" model="ir.actions.report">
        <field name="name">Export Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.export_invoice_template</field>
        <field name="report_file">export_docs.export_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="export_invoice_template" t-name="export_docs.export_invoice_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                
                <!-- ✅ FIXED WIZARD DATA -->
                <t t-set="wiz" t-value="data.get('wizard_data', {})"/>

                <t t-set="is_lut" t-value="o.fiscal_position_id and o.fiscal_position_id.name == 'Export - LUT (WOP)'"/>
                <t t-set="inv_currency" t-value="o.currency_id" />

                <!-- BUYER ORDER -->
                <t t-set="buyer_orders" t-value="[]" />
                <t t-foreach="o.invoice_line_ids" t-as="l">
                    <t t-foreach="l.sale_line_ids" t-as="sl">
                        <t t-if="sl.order_id and sl.order_id.buyer_order_no">
                            <t t-if="sl.order_id.buyer_order_no not in buyer_orders">
                                <t t-set="buyer_orders" t-value="buyer_orders + [sl.order_id.buyer_order_no]" />
                            </t>
                        </t>
                    </t>
                </t>

                <!-- ✅ PRODUCT FILTER FIX -->
                <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: not l.display_type)" />

                <!-- TOTALS -->
                <t t-set="insurance_total" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service' and 'insurance' in (l.product_id.name or '').lower()).mapped('price_subtotal')) or 0.0" />
                <t t-set="freight_total" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service' and 'freight' in (l.product_id.name or '').lower()).mapped('price_subtotal')) or 0.0" />
                
                <t t-set="goods_gross" t-value="sum(product_lines.mapped(lambda l: l.quantity * l.price_unit))" />
                <t t-set="discount_total" t-value="sum(product_lines.mapped(lambda l: (l.quantity * l.price_unit * l.discount) / 100)) or 0.0" />
                <t t-set="product_net" t-value="goods_gross - discount_total" />

                <t t-set="net_cf" t-value="product_net + freight_total" />
                <t t-set="net_cif" t-value="net_cf + insurance_total" />

                <!-- AMOUNT WORDS -->
                <t t-set="val_for_words" t-value="o.amount_total" />
                <t t-if="wiz.get('show_net_amount')"><t t-set="val_for_words" t-value="product_net"/></t>
                <t t-elif="wiz.get('show_net_cf')"><t t-set="val_for_words" t-value="net_cf"/></t>
                <t t-elif="wiz.get('show_net_cif')"><t t-set="val_for_words" t-value="net_cif"/></t>

                <div class="page" style="font-size:12px; font-family: 'Times New Roman', serif;">
                    <style>
                        table { width: 100%; border-collapse: collapse; border: 1px solid #000; }
                        th, td { border: 1px solid #000; padding: 4px; vertical-align: top; }
                        .text-right { text-align: right; } 
                        .text-center { text-align: center; }
                        .bg-light { background: #f2f2f2; font-weight: bold; }
                        .title { font-size: 25px; font-weight: bold; text-align: center; margin-bottom:10px; }
                    </style>

                    <div class="title">EXPORT INVOICE</div>

                    <!-- HEADER -->
                    <table>
                        <tr>
                            <td width="60%">
                                <strong>Exporter</strong><br/>
                                <strong><t t-esc="o.company_id.name" /></strong><br/>
                                <t t-esc="o.company_id.street" /><br/>
                                <t t-esc="o.company_id.city" />, <t t-esc="o.company_id.country_id.name" /><br/>
                                <strong>GSTIN :</strong> <t t-esc="o.company_id.vat" />
                            </td>
                            <td width="40%">
                                <strong>Invoice No :</strong> <t t-esc="o.name" /><br/>
                                <strong>Date :</strong> <t t-esc="o.invoice_date" /><br/>
                                <strong>Buyer Order :</strong> <t t-esc="' / '.join(buyer_orders)" />
                            </td>
                        </tr>
                    </table>

                    <!-- ITEMS -->
                    <table>
                        <thead>
                            <tr class="bg-light">
                                <th>Sr</th>
                                <th>Item Ref</th>
                                <th>Description</th>
                                <th>HSN</th>
                                <th>Qty</th>
                                <th>Rate</th>
                                <th>Amount</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-set="sr" t-value="1" />

                            <t t-foreach="product_lines" t-as="line">
                                <tr>

                                    <td class="text-center"><t t-esc="sr"/></td>

                                    <!-- PRODUCT CODE -->
                                    <td>
                                        <t t-set="tmpl" t-value="line.product_id.product_tmpl_id"/>
                                        <t t-set="partner" t-value="o.partner_id"/>
                                        <t t-set="mapping"
                                            t-value="tmpl.customer_sku_ids.filtered(lambda m: m.customer_id.id == partner.id)"/>

                                        <t t-if="wiz.get('description_mode') == 'buyer' and mapping">
                                            <t t-esc="mapping[0].buyer_sku"/>
                                        </t>
                                        <t t-else="">
                                            <t t-esc="line.product_id.default_code or ''"/>
                                        </t>
                                    </td>

                                    <!-- DESCRIPTION -->
                                    <td>
                                        <t t-if="wiz.get('description_mode') == 'buyer' and mapping">
                                            <t t-esc="mapping[0].customer_description"/>
                                        </t>
                                        <t t-elif="wiz.get('description_mode') == 'exporter' and tmpl.export_description">
                                            <t t-esc="tmpl.export_description"/>
                                        </t>
                                        <t t-elif="wiz.get('description_mode') == 'foreign' and tmpl.foreign_description">
                                            <t t-esc="tmpl.foreign_description"/>
                                        </t>
                                        <t t-else="">
                                            <t t-esc="line.name"/>
                                        </t>
                                    </td>

                                    <td class="text-center"><t t-esc="line.product_id.l10n_in_hsn_code or ''"/></td>
                                    <td class="text-right"><t t-esc="line.quantity"/></td>
                                    <td class="text-right"><t t-esc="line.price_unit"/></td>
                                    <td class="text-right"><t t-esc="line.price_subtotal"/></td>

                                </tr>

                                <t t-set="sr" t-value="sr + 1"/>
                            </t>

                        </tbody>
                    </table>

                </div>
            </t>
        </t>
    </template>

</odoo>
