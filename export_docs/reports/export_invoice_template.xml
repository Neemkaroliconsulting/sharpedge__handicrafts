<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="paperformat_export_a4" model="report.paperformat">
        <field name="name">Export Invoice A4 Clean</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
        <field name="header_line" eval="False"/>
    </record>

    <record id="action_export_invoice_report" model="ir.actions.report">
        <field name="name">Export Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.export_invoice_template</field>
        <field name="report_file">export_docs.export_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="export_invoice_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                
                <t t-set="inv_currency" t-value="o.currency_id" />
                
                <t t-set="wiz_summary"
   t-value="o.env.context.get('wizard_data', {}).get('amount_summary')" />
                <t t-set="desc_mode"
   t-value="o.env.context.get('wizard_data', {}).get('description_mode')" />

                <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service' and 'freight' not in (l.name or '').lower() and 'insurance' not in (l.name or '').lower())" />
                
                <t t-set="goods_gross" t-value="sum(product_lines.mapped('price_subtotal')) or 0.0" />
                <t t-set="freight_val" t-value="sum(o.invoice_line_ids.filtered(lambda l: 'freight' in (l.name or '').lower()).mapped('price_subtotal')) or 0.0" />
                <t t-set="insurance_val" t-value="sum(o.invoice_line_ids.filtered(lambda l: 'insurance' in (l.name or '').lower()).mapped('price_subtotal')) or 0.0" />
                <t t-set="discount_total" t-value="sum(product_lines.mapped(lambda l: (l.quantity * l.price_unit * l.discount) / 100)) or 0.0" />
                <t t-set="net_amount_val" t-value="goods_gross - discount_total" />
                <t t-set="total_pcs" t-value="sum(product_lines.mapped('quantity')) or 0" />

                <t t-set="display_total" t-value="o.amount_total or 0.0" />
                <t t-set="display_label" t-value="'GRAND TOTAL'" />

                <t t-if="wiz_summary == 'show_net_cf'">
    <t t-set="display_total" t-value="net_amount_val + freight_val" />
    <t t-set="display_label" t-value="'NET C&amp;F'" />
</t>

<t t-elif="wiz_summary == 'show_net_cif'">
    <t t-set="display_total" t-value="net_amount_val + freight_val + insurance_val" />
    <t t-set="display_label" t-value="'NET CI&amp;F'" />
</t>

                <div class="page" style="font-size:11px; font-family: 'Times New Roman', serif;">
                    <style>
                        .main-table { width: 100%; border-collapse: collapse; border: 1px solid #000; }
                        .main-table th, .main-table td { border: 1px solid #000; padding: 4px; vertical-align: top; }
                        .text-right { text-align: right; } .text-center { text-align: center; }
                        .bg-light { background: #f2f2f2; font-weight: bold; }
                    </style>

                    <h3 class="text-center" style="margin-bottom:10px;">INVOICE</h3>

                    <table class="main-table">
                        <thead>
                            <tr class="bg-light text-center">
                                <th width="5%">Sr.</th>
                                <th width="15%">Sr.</th>
                                <th width="30%">Description of Goods</th>
                                <th width="10%">HSN</th>
                                <th width="10%">Quantity</th>
                                <th width="15%">Rate (<t t-esc="inv_currency.name"/>)</th>
                                <th width="15%">Amount (<t t-esc="inv_currency.name"/>)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sr" t-value="1"/>
                            <t t-foreach="product_lines" t-as="line">
                                <tr>
                                    <td class="text-center"><t t-esc="sr"/></td>
                                    <td class="text-center">

    <!-- Export Mode -->
    <t t-if="desc_mode == 'export'">
        <t t-esc="line.product_id.default_code or ''"/>
    </t>

    <!-- Buyer Mode -->
    <t t-elif="desc_mode == 'buyer'">
        <t t-esc="line.product_id.buyer_code or line.product_id.default_code or ''"/>
    </t>

    <!-- Foreign Mode -->
    <t t-elif="desc_mode == 'foreign'">
        <t t-esc="line.product_id.foreign_code or line.product_id.default_code or ''"/>
    </t>

    <!-- Fallback -->
    <t t-else="">
        <t t-esc="line.product_id.default_code or ''"/>
    </t>

</td>
                                    <td>
    <!-- Exporter Description -->
    <t t-if="desc_mode == 'export'">
        <t t-esc="line.name"/>
    </t>

    <!-- Buyer Description -->
    <t t-elif="desc_mode == 'buyer'">
        <t t-esc="line.product_id.description_sale or line.name"/>
    </t>

    <!-- Foreign Language -->
    <t t-elif="desc_mode == 'foreign'">
        <t t-esc="line.product_id.name"/>
    </t>

    <!-- Default fallback -->
    <t t-else="">
        <t t-esc="line.name"/>
    </t>
</td>
                                    <td class="text-center"><t t-esc="line.product_id.l10n_in_hsn_code or ''"/></td>
                                    <td class="text-right"><t t-esc="line.quantity"/> Pcs</td>
                                    <td class="text-right"><t t-esc="line.price_unit" t-options='{"widget": "float", "precision": 2}'/></td>
                                    <td class="text-right"><t t-esc="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/></td>
                                </tr>
                                <t t-set="sr" t-value="sr + 1"/>
                            </t>
                            <tr class="bg-light">
                                <td colspan="3" class="text-right">TOTAL</td>
                                <td class="text-right"><t t-esc="total_pcs"/> Pcs</td>
                                <td></td>
                                <td class="text-right"><t t-esc="inv_currency.format(goods_gross)"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <table class="main-table" style="border-top: none;">
                        <tr>
                            <td width="55%" style="padding:10px;">
                                <strong>Total PCS:</strong><br/>
                                <em><t t-esc="int(total_pcs)"/> Pieces Only</em><br/><br/>
                                <strong>Amount Chargeable (In Words):</strong><br/>
<em>

    <!-- Prefix based on CF / CIF -->
    <t t-if="wiz_summary == 'show_net_cf'">
        NET C&amp;F 
    </t>
    <t t-elif="wiz_summary == 'show_net_cif'">
        NET CI&amp;F 
    </t>

    <t t-esc="inv_currency.name"/>
    <t t-esc="o.currency_id.amount_to_text(display_total)"/> Only

</em>
                            </td>
                            <td width="45%" style="padding:0;">
                                <table style="width:100%; border:none;">
                                    <tr>
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">LESS: DISCOUNT</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;">- <t t-esc="inv_currency.format(discount_total)"/></td>
                                    </tr>
                                    <tr class="bg-light">
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">NET AMOUNT</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(net_amount_val)"/></td>
                                    </tr>
                                    
                                    <t t-if="freight_val &gt; 0">
                                        <tr>
                                            <td style="border:none; border-bottom:1px solid #000; padding:4px;">ADD: FREIGHT (+)</td>
                                            <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(freight_val)"/></td>
                                        </tr>
                                    </t>

                                    <t t-if="insurance_val &gt; 0">
                                        <tr>
                                            <td style="border:none; border-bottom:1px solid #000; padding:4px;">ADD: INSURANCE (+)</td>
                                            <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(insurance_val)"/></td>
                                        </tr>
                                    </t>

                                    <tr class="bg-light">
                                        <td style="border:none; padding:4px;">
                                            <strong><t t-esc="display_label"/></strong>
                                        </td>
                                        <td class="text-right" style="border:none; border-left:1px solid #000;">
                                            <strong><t t-esc="inv_currency.format(display_total)"/></strong>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                    <table class="main-table" style="border-top: none;">
    <tr class="bg-light text-center">
        
        <!-- Net Weight -->
        <td>
            <strong>Net Wt:</strong>
            <t t-esc="round(sum(product_lines.mapped('quantity')), 2)"/> Kgs
        </td>

        <!-- Gross Weight -->
        <td>
            <strong>Gross Wt:</strong>
            <t t-esc="round(sum(product_lines.mapped('quantity')), 2)"/> Kgs
        </td>

        <!-- Total Packages -->
        <td>
            <strong>Total PKGS:</strong>
            <t t-esc="len(product_lines)"/>
        </td>

    </tr>
</table>

                    <table class="main-table" style="border-top: none;">
                        <tr>
                            <td width="55%" style="padding:5px;">
                                <strong>DECLARATION:</strong> We declare that this invoice shows the actual price of the goods described.
                            </td>
                            <td width="45%" class="text-center" style="vertical-align:bottom; height:60px;">
                                For <strong><t t-esc="o.company_id.name"/></strong><br/><br/>
                                Authorised Signatory
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
