<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================= PAPER FORMAT ================= -->
    <record id="paperformat_export_a4" model="report.paperformat">
        <field name="name">Export Invoice A4 Clean</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
    </record>

    <!-- ================= REPORT ACTION ================= -->
    <record id="action_export_invoice_report" model="ir.actions.report">
        <field name="name">Export Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.export_invoice_template</field>
        <field name="report_file">export_docs.export_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <!-- ================= TEMPLATE ================= -->
    <template id="export_invoice_template" t-name="export_docs.export_invoice_template">
    <t t-call="web.basic_layout">

        <t t-foreach="docs" t-as="o">

            <!-- ================= CALCULATIONS ================= -->

            <!-- INSURANCE -->
            <t t-set="insurance_total"
                t-value="sum(o.invoice_line_ids.filtered(
                    lambda l: l.product_id and l.product_id.type == 'service' and 'insurance' in (l.product_id.name or '').lower()
                ).mapped('price_subtotal')) or 0.0" />

            <!-- FREIGHT -->
            <t t-set="freight_total"
                t-value="sum(o.invoice_line_ids.filtered(
                    lambda l: l.product_id and l.product_id.type == 'service' and 'freight' in (l.product_id.name or '').lower()
                ).mapped('price_subtotal')) or 0.0" />

            <!-- DISCOUNT -->
            <t t-set="discount_amount"
                t-value="sum(o.invoice_line_ids.filtered(
                    lambda l: l.product_id and l.product_id.type != 'service'
                ).mapped(lambda l: (l.quantity * l.price_unit * l.discount) / 100)) or 0.0" />

            <!-- PRODUCT TOTAL -->
            <t t-set="product_total"
                t-value="sum(o.invoice_line_ids.filtered(
                    lambda l: l.product_id and l.product_id.type != 'service'
                ).mapped('price_subtotal')) or 0.0" />

            <!-- NET -->
            <t t-set="net_amount" t-value="product_total"/>
            <t t-set="net_cf" t-value="net_amount + freight_total"/>
            <t t-set="net_cif" t-value="net_cf + insurance_total"/>

            <div class="page" style="font-size:14px;">

                <!-- ================= TITLE ================= -->
                <div style="text-align:center; font-size:22px; font-weight:bold;">
                    EXPORT INVOICE
                </div>

                <!-- ================= HEADER ================= -->
                <table>
                    <tr>
                        <td width="60%">
                            <strong>Exporter</strong><br/>
                            <t t-esc="o.company_id.name"/><br/>
                            <t t-esc="o.company_id.street"/><br/>
                            <t t-esc="o.company_id.city"/> ,
                            <t t-esc="o.company_id.country_id.name"/>
                        </td>

                        <td width="40%">
                            <strong>Invoice No:</strong> <t t-esc="o.name"/><br/>
                            <strong>Date:</strong> <t t-esc="o.invoice_date"/><br/>
                            <strong>Exporter Ref:</strong> <t t-esc="o.exporter_reference"/>
                        </td>
                    </tr>
                </table>

                <!-- ================= PARTIES ================= -->
                <table>
                    <tr>
                        <td width="50%">
                            <strong>Consignee</strong><br/>
                            <t t-esc="o.consignee_id.name"/><br/>
                            <t t-esc="o.consignee_id.street"/><br/>
                            <t t-esc="o.consignee_id.city"/> ,
                            <t t-esc="o.consignee_id.country_id.name"/>
                        </td>

                        <td width="50%">
                            <strong>Buyer</strong><br/>
                            <t t-esc="o.buyer_id.name"/>
                        </td>
                    </tr>
                </table>

                <!-- ================= SHIPPING ================= -->
                <table>
                    <tr>
                        <td>Country of Origin<br/><strong><t t-esc="o.country_origin_id.name"/></strong></td>
                        <td>Final Destination<br/><strong><t t-esc="o.country_destination_id.name"/></strong></td>
                    </tr>
                    <tr>
                        <td>Port of Loading<br/><strong><t t-esc="o.port_loading"/></strong></td>
                        <td>Port of Discharge<br/><strong><t t-esc="o.port_discharge"/></strong></td>
                    </tr>
                </table>

                <!-- ================= ITEM TABLE ================= -->
                <table border="1" style="width:100%; border-collapse:collapse; margin-top:10px;">
                    <thead>
                        <tr>
                            <th>Sr</th>
                            <th>Item Ref</th>
                            <th>Description</th>
                            <th>HSN</th>
                            <th>Qty</th>
                            <th>Rate</th>
                            <th>Amount</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-set="sr" t-value="1"/>

                        <t t-foreach="o.invoice_line_ids" t-as="line">

                            <!-- ✅ FINAL FILTER -->
                            <t t-if="not line.display_type 
                                     and line.product_id 
                                     and line.product_id.type != 'service'
                                     and line.show_in_invoice">

                                <tr>
                                    <td><t t-esc="sr"/></td>

                                    <td>
                                        <t t-esc="line.product_id.default_code or ''"/>
                                    </td>

                                    <td>
                                        <t t-esc="line.name"/>
                                    </td>

                                    <td>
                                        <t t-esc="line.product_id.l10n_in_hsn_code or ''"/>
                                    </td>

                                    <td>
                                        <t t-esc="line.quantity"/>
                                    </td>

                                    <td>
                                        <t t-esc="line.price_unit"/>
                                    </td>

                                    <td>
                                        <t t-esc="line.price_subtotal"/>
                                    </td>
                                </tr>

                                <t t-set="sr" t-value="sr + 1"/>

                            </t>
                        </t>
                    </tbody>
                </table>

                <!-- ================= TOTAL ================= -->
                <table style="margin-top:10px;">
                    <tr>
                        <td width="60%">
                            <strong>Amount in Words</strong><br/>
                            <t t-esc="o.currency_id.amount_to_text(net_cf)"/>
                        </td>

                        <td width="40%">
                            <table>
                                <tr>
                                    <td>DISCOUNT</td>
                                    <td><t t-esc="round(discount_amount,2)"/></td>
                                </tr>
                                <tr>
                                    <td>FREIGHT</td>
                                    <td><t t-esc="round(freight_total,2)"/></td>
                                </tr>
                                <tr>
                                    <td>INSURANCE</td>
                                    <td><t t-esc="round(insurance_total,2)"/></td>
                                </tr>
                                <tr>
                                    <td><strong>NET C&amp;F</strong></td>
                                    <td><strong><t t-esc="round(net_cf,2)"/></strong></td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- ================= WEIGHT ================= -->
                <table>
                    <tr>
                        <td>Total Net Weight<br/><t t-esc="o.net_weight"/></td>
                        <td>Total Gross Weight<br/><t t-esc="o.gross_weight"/></td>
                        <td>Total Packages<br/><t t-esc="o.total_packages"/></td>
                    </tr>
                </table>

                <!-- ================= DECLARATION ================= -->
                <table>
                    <tr>
                        <td>
                            <strong>Declaration:</strong><br/>
                            We declare that this invoice shows correct details.
                        </td>
                        <td style="text-align:right;">
                            For <t t-esc="o.company_id.name"/><br/><br/>
                            Authorised Signatory
                        </td>
                    </tr>
                </table>

            </div>
        </t>
    </t>
</template>

</odoo>
