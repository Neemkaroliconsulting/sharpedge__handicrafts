<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="paperformat_export_a4" model="report.paperformat">
        <field name="name">Export Invoice A4 Clean</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
    </record>

    <record id="action_export_invoice_report" model="ir.actions.report">
        <field name="name">Export Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.export_invoice_template</field>
        <field name="report_file">export_docs.export_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="export_invoice_template" t-name="export_docs.export_invoice_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                
                <t t-set="wiz" t-value="o._context.get('wizard_data', {})" />
                <t t-set="inv_currency" t-value="o.currency_id" />

                <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service')" />
                <t t-set="goods_gross" t-value="sum(product_lines.mapped(lambda l: l.quantity * l.price_unit))" />
                <t t-set="discount_total" t-value="sum(product_lines.mapped(lambda l: (l.quantity * l.price_unit * l.discount) / 100))" />
                <t t-set="net_amount_val" t-value="goods_gross - discount_total" />
                
                <t t-set="freight_val" t-value="sum(o.invoice_line_ids.filtered(lambda l: not l.display_type and ('freight' in (l.name or '').lower() or (l.product_id and 'freight' in (l.product_id.name or '').lower()))).mapped('price_subtotal'))" />
                <t t-set="insurance_val" t-value="sum(o.invoice_line_ids.filtered(lambda l: not l.display_type and ('insurance' in (l.name or '').lower() or (l.product_id and 'insurance' in (l.product_id.name or '').lower()))).mapped('price_subtotal'))" />
                
                <t t-set="net_cf" t-value="net_amount_val + freight_val" />
                <t t-set="net_cif" t-value="net_cf + insurance_val" />
                <t t-set="total_pcs_num" t-value="int(sum(product_lines.mapped('quantity')))" />

                <t t-set="pcs_in_words" t-value="o.company_id.currency_id.amount_to_text(total_pcs_num).replace(o.company_id.currency_id.name, '').replace('Cents', '').replace('Cent', '').strip()" />

                <t t-set="word_label" t-value="''" />
                <t t-set="word_val" t-value="o.amount_total" />
                <t t-if="wiz.get('amount_summary') == 'cf'">
                    <t t-set="word_val" t-value="net_cf"/><t t-set="word_label" t-value="'C&amp;F'"/>
                </t>
                <t t-elif="wiz.get('amount_summary') == 'cif'">
                    <t t-set="word_val" t-value="net_cif"/><t t-set="word_label" t-value="'CIF'"/>
                </t>

                <div class="page" style="font-size:11px; font-family: 'Times New Roman', serif;">
                    <table style="width: 100%; border: 1px solid #000; border-collapse: collapse;">
                        <tr>
                            <td width="55%" style="padding:10px; border-right: 1px solid #000;">
                                <strong>Total PCS:</strong><br/>
                                <em><t t-esc="pcs_in_words"/> Pieces Only</em>
                                <br/><br/>
                                <strong>Amount Chargeable (In Words):</strong><br/>
                                <em><t t-if="word_label"><t t-esc="word_label"/> </t><t t-esc="inv_currency.name"/> <t t-esc="inv_currency.amount_to_text(word_val)"/> Only</em>
                            </td>
                            <td width="45%" style="padding:0;">
                                <table style="width:100%; border:none;">
                                    <tr>
                                        <td style="border-bottom:1px solid #000; padding:4px;">LESS: DISCOUNT</td>
                                        <td style="text-align: right; border-bottom:1px solid #000; border-left:1px solid #000;">- <t t-esc="inv_currency.format(discount_total)"/></td>
                                    </tr>
                                    <tr style="background:#f2f2f2;">
                                        <td style="border-bottom:1px solid #000; padding:4px;"><strong>NET AMOUNT</strong></td>
                                        <td style="text-align: right; border-bottom:1px solid #000; border-left:1px solid #000;"><strong><t t-esc="inv_currency.format(net_amount_val)"/></strong></td>
                                    </tr>
                                    <tr>
                                        <td style="border-bottom:1px solid #000; padding:4px;">ADD: FREIGHT (+)</td>
                                        <td style="text-align: right; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(freight_val)"/></td>
                                    </tr>
                                    
                                    <t t-if="wiz.get('amount_summary') == 'cf'">
                                        <tr style="background:#f2f2f2;">
                                            <td style="border-bottom:1px solid #000; padding:4px;"><strong>NET C&amp;F</strong></td>
                                            <td style="text-align: right; border-bottom:1px solid #000; border-left:1px solid #000;"><strong><t t-esc="inv_currency.format(net_cf)"/></strong></td>
                                        </tr>
                                    </t>

                                    <tr>
                                        <td style="border-bottom:1px solid #000; padding:4px;">ADD: INSURANCE (+)</td>
                                        <td style="text-align: right; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(insurance_val)"/></td>
                                    </tr>

                                    <t t-if="wiz.get('amount_summary') == 'cif'">
                                        <tr style="background:#f2f2f2;">
                                            <td style="border-bottom:1px solid #000; padding:4px;"><strong>NET CIF</strong></td>
                                            <td style="text-align: right; border-bottom:1px solid #000; border-left:1px solid #000;"><strong><t t-esc="inv_currency.format(net_cif)"/></strong></td>
                                        </tr>
                                    </t>
                                </table>
                            </td>
                        </tr>
                    </table>
                    </div>
            </t>
        </t>
    </template>
</odoo>
