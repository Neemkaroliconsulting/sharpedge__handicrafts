<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="paperformat_export_a4" model="report.paperformat">
        <field name="name">Export Invoice A4 Clean</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
    </record>

    <record id="action_export_invoice_report" model="ir.actions.report">
        <field name="name">Export Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.export_invoice_template</field>
        <field name="report_file">export_docs.export_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="export_invoice_template" t-name="export_docs.export_invoice_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                
                <t t-set="wiz" t-value="o._context.get('wizard_data', {})" />
                <t t-set="inv_currency" t-value="o.currency_id" />

                <t t-set="buyer_orders" t-value="[]" />
                <t t-foreach="o.invoice_line_ids" t-as="l">
                    <t t-foreach="l.sale_line_ids" t-as="sl">
                        <t t-if="sl.order_id and sl.order_id.buyer_order_no and sl.order_id.buyer_order_no not in buyer_orders">
                            <t t-set="buyer_orders" t-value="buyer_orders + [sl.order_id.buyer_order_no]" />
                        </t>
                    </t>
                </t>

                <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service')" />
                <t t-set="goods_gross" t-value="sum(product_lines.mapped(lambda l: l.quantity * l.price_unit))" />
                <t t-set="discount_total" t-value="sum(product_lines.mapped(lambda l: (l.quantity * l.price_unit * l.discount) / 100))" />
                <t t-set="net_amount_val" t-value="goods_gross - discount_total" />
                
                <t t-set="freight_val" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and 'freight' in (l.product_id.name or '').lower()).mapped('price_subtotal'))" />
                <t t-set="insurance_val" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and 'insurance' in (l.product_id.name or '').lower()).mapped('price_subtotal'))" />
                
                <t t-set="net_cf" t-value="net_amount_val + freight_val" />
                <t t-set="net_cif" t-value="net_cf + insurance_val" />

                <t t-set="word_label" t-value="''" />
                <t t-set="word_val" t-value="o.amount_total" />
                <t t-if="wiz.get('show_net_cf')">
                    <t t-set="word_val" t-value="net_cf"/>
                    <t t-set="word_label" t-value="'C&amp;F'"/>
                </t>
                <t t-elif="wiz.get('show_net_cif')">
                    <t t-set="word_val" t-value="net_cif"/>
                    <t t-set="word_label" t-value="'CIF'"/>
                </t>

                <div class="page" style="font-size:11px; font-family: 'Times New Roman', serif;">
                    <style>
                        table { width: 100%; border-collapse: collapse; border: 1px solid #000; }
                        th, td { border: 1px solid #000; padding: 4px; vertical-align: top; }
                        .text-right { text-align: right; } .text-center { text-align: center; }
                        .bg-light { background: #f2f2f2; font-weight: bold; }
                        .no-top { border-top: none; }
                    </style>

                    <h3 class="text-center" style="margin-bottom:10px;">INVOICE</h3>

                    <table>
                        <tr>
                            <td width="50%">
                                <strong>Exporter</strong><br/>
                                <strong><t t-esc="o.company_id.name"/></strong><br/>
                                <t t-esc="o.company_id.street"/>, <t t-esc="o.company_id.city"/><br/>
                                <strong>GSTIN:</strong> <t t-esc="o.company_id.vat"/>
                            </td>
                            <td width="50%">
                                <strong>Invoice No.:</strong> <t t-esc="o.name"/><br/>
                                <strong>Invoice Dt.:</strong> <t t-esc="o.invoice_date"/><br/>
                                <strong>Buyer's Order No.:</strong> <t t-esc="' / '.join(buyer_orders)"/>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Consignee:</strong><br/><t t-esc="o.consignee_id.name"/><br/><t t-esc="o.consignee_id.street"/>, <t t-esc="o.consignee_id.city"/></td>
                            <td><strong>Buyer (if other than consignee):</strong><br/><t t-esc="o.buyer_id.name"/></td>
                        </tr>
                    </table>

                    <table class="no-top">
                        <tr>
                            <td>Country of Origin: <strong><t t-esc="o.country_origin_id.name"/></strong></td>
                            <td>Final Destination: <strong><t t-esc="o.country_destination_id.name"/></strong></td>
                        </tr>
                        <tr>
                            <td>Pre-Carriage By: <strong><t t-esc="o.pre_carriage_by"/></strong></td>
                            <td>Place of Receipt: <strong><t t-esc="o.place_of_receipt"/></strong></td>
                        </tr>
                        <tr>
                            <td>Port of Loading: <strong><t t-esc="o.port_loading"/></strong></td>
                            <td>Port of Discharge: <strong><t t-esc="o.port_discharge"/></strong></td>
                        </tr>
                        <tr>
                            <td colspan="2">Terms: <t t-esc="o.terms_delivery"/> / <t t-esc="o.payment_terms_export"/></td>
                        </tr>
                    </table>

                    <table class="no-top">
                        <thead>
                            <tr class="bg-light text-center">
                                <th width="5%">Sr.</th>
                                <th width="40%">Description of Goods</th>
                                <th width="10%">HSN</th>
                                <th width="10%">Quantity</th>
                                <th width="15%">Rate (<t t-esc="inv_currency.name"/>)</th>
                                <th width="20%">Amount (<t t-esc="inv_currency.name"/>)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sr" t-value="1"/>
                            <t t-set="total_pcs" t-value="0"/>
                            <t t-foreach="product_lines" t-as="line">
                                <tr>
                                    <td class="text-center"><t t-esc="sr"/></td>
                                    <td><t t-esc="line.name"/></td>
                                    <td class="text-center"><t t-esc="line.product_id.l10n_in_hsn_code or '' "/></td>
                                    <td class="text-right">
                                        <t t-esc="line.quantity"/> Pcs 
                                        <t t-set="total_pcs" t-value="total_pcs + line.quantity"/>
                                    </td>
                                    <td class="text-right"><t t-esc="round(line.price_unit, 2)"/></td>
                                    <td class="text-right"><t t-esc="round(line.price_subtotal, 2)"/></td>
                                </tr>
                                <t t-set="sr" t-value="sr + 1"/>
                            </t>
                            <t t-foreach="range(3)" t-as="i"><tr style="height:20px;"><td></td><td></td><td></td><td></td><td></td><td></td></tr></t>
                            <tr class="bg-light">
                                <td colspan="3" class="text-right"><strong>TOTAL PCS:</strong></td>
                                <td class="text-right"><strong><t t-esc="int(total_pcs)"/></strong></td>
                                <td colspan="2"></td>
                            </tr>
                        </tbody>
                    </table>

                    <table class="no-top">
                        <tr>
                            <td width="55%" style="padding:10px;">
                                <strong>Amount Chargeable (In Words):</strong><br/>
                                <em><t t-esc="word_label"/> <t t-esc="inv_currency.name"/> <t t-esc="inv_currency.amount_to_text(word_val)"/> Only</em>
                                <br/><br/>
                                <strong>Declaration:</strong> We declare that this invoice shows the actual price of the goods described.
                            </td>
                            <td width="45%" style="padding:0;">
                                <table style="width:100%; border:none;">
                                    <tr>
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">LESS: DISCOUNT</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;">- <t t-esc="inv_currency.format(discount_total)"/></td>
                                    </tr>
                                    <tr class="bg-light">
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">NET AMOUNT</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(net_amount_val)"/></td>
                                    </tr>
                                    <tr>
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">ADD: FREIGHT (+)</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(freight_val)"/></td>
                                    </tr>
                                    <tr t-if="wiz.get('show_net_cf')" class="bg-light">
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">NET C&amp;F</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(net_cf)"/></td>
                                    </tr>
                                    <tr>
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">ADD: INSURANCE (+)</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(insurance_val)"/></td>
                                    </tr>
                                    <tr t-if="wiz.get('show_net_cif')" class="bg-light">
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">NET CIF</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(net_cif)"/></td>
                                    </tr>
                                    <tr style="background:#ddd; font-weight:bold;">
                                        <td style="border:none; padding:4px;">GRAND TOTAL</td>
                                        <td class="text-right" style="border:none; border-left:1px solid #000;"><t t-esc="inv_currency.format(o.amount_total)"/></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <table class="no-top">
                        <tr class="text-center">
                            <td>TOTAL NET WT (Kgs): <strong><t t-esc="round(o.net_weight or 0, 3)"/></strong></td>
                            <td>GROSS WT (Kgs): <strong><t t-esc="round(o.gross_weight or 0, 3)"/></strong></td>
                            <td>Total PKGS: <strong><t t-esc="o.total_packages or 0"/></strong></td>
                        </tr>
                    </table>

                    <table class="no-top">
                        <tr>
                            <td class="text-right" style="height:60px; vertical-align:bottom;">
                                For <strong><t t-esc="o.company_id.name"/></strong><br/><br/>
                                Authorised Signatory
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
