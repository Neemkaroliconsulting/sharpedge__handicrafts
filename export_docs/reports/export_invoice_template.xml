                            </td>
                            <td width="50%" colspan="2"><strong>Buyer (if other than consignee)</strong><br/><span>Same as Consignee</span></td>
                        </tr>
                        <tr>
                            <td>Country of Origin: <strong><t t-esc="o.company_id.country_id.name"/></strong></td>
                            <td colspan="2">Final Destination: <strong><t t-esc="o.partner_id.country_id.name"/></strong></td>
                        </tr>
                        <tr>
                            <td>Port of Loading: <strong><t t-esc="o.l10n_in_shipping_port_code or 'N/A'"/></strong></td>
                            <td colspan="2">Port of Discharge: <strong><t t-esc="o.partner_id.city"/></strong></td>
                        </tr>
                    </table> -->

                    <table class="main-table" style="border-top: none;">
                        <thead>
                            <tr class="bg-light text-center">
                                <th width="5%">Sr.</th>
                                <th width="45%">Description of Goods</th>
                                <th width="10%">HSN</th>
                                <th width="10%">Quantity</th>
                                <th width="15%">Rate (<t t-esc="inv_currency.name"/>)</th>
                                <th width="15%">Amount (<t t-esc="inv_currency.name"/>)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sr" t-value="1"/>
                            <t t-foreach="product_lines" t-as="line">
                                <tr>
                                    <td class="text-center"><t t-esc="sr"/></td>
                                    <td><t t-esc="line.name"/></td>
                                    <td class="text-center"><t t-esc="line.product_id.l10n_in_hsn_code or ''"/></td>
                                    <td class="text-right"><t t-esc="line.quantity"/> Pcs</td>
                                    <td class="text-right"><t t-esc="line.price_unit" t-options='{"widget": "float", "precision": 2}'/></td>
                                    <td class="text-right"><t t-esc="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/></td>
                                </tr>
                                <t t-set="sr" t-value="sr + 1"/>
                            </t>
                            <tr style="height:20px;"><td colspan="6"></td></tr>
                            <tr class="bg-light">
                                <td colspan="3" class="text-right">TOTAL</td>
                                <td class="text-right"><t t-esc="total_pcs"/> Pcs</td>
                                <td></td>
                                <td class="text-right"><t t-esc="inv_currency.format(goods_gross)"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <table class="main-table" style="border-top: none;">
                        <tr>
                            <td width="55%" style="padding:10px;">
                                <strong>Total PCS:</strong><br/>
                                <em><t t-esc="int(total_pcs)"/> Pieces Only</em><br/><br/>
                                <strong>Amount Chargeable (In Words):</strong><br/>
                                <em><t t-esc="inv_currency.name"/> <t t-esc="o.currency_id.amount_to_text(o.amount_total)"/> Only</em>
                            </td>
                            <td width="45%" style="padding:0;">
                                <table style="width:100%; border:none;">
                                    <tr>
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">LESS: DISCOUNT</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;">- <t t-esc="inv_currency.format(discount_total)"/></td>
                                    </tr>
                                    <tr class="bg-light">
                                        <td style="border:none; border-bottom:1px solid #000; padding:4px;">NET AMOUNT</td>
                                        <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(net_amount_val)"/></td>
                                    </tr>
                                    
                                    <t t-if="freight_val &gt; 0">
                                        <tr>
                                            <td style="border:none; border-bottom:1px solid #000; padding:4px;">ADD: FREIGHT (+)</td>
                                            <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(freight_val)"/></td>
                                        </tr>
                                    </t>

                                    <t t-if="insurance_val &gt; 0">
                                        <tr>
                                            <td style="border:none; border-bottom:1px solid #000; padding:4px;">ADD: INSURANCE (+)</td>
                                            <td class="text-right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(insurance_val)"/></td>
                                        </tr>
                                    </t>

                                    <tr class="bg-light">
                                        <td style="border:none; padding:4px;"><strong>GRAND TOTAL</strong></td>
                                        <td class="text-right" style="border:none; border-left:1px solid #000;"><strong><t t-esc="inv_currency.format(o.amount_total)"/></strong></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <table class="main-table" style="border-top: none;">
                        <tr>
                            <td width="55%" style="padding:0;">
                                <table style="width:100%; border:none;">
                                    <tr class="text-center">
                                        <td style="border:none; border-right:1px solid #000;">Net Wt: <t t-esc="o.l10n_in_shipping_bill_number or '0'"/> Kgs</td>
                                        <td style="border:none; border-right:1px solid #000;">Gross Wt: 0 Kgs</td>
                                        <td style="border:none;">Total PKGS: 0</td>
                                    </tr>
                                </table>
                                <div style="padding:5px; border-top:1px solid #000; font-size:10px;">
                                    <strong>DECLARATION:</strong> We declare that this invoice shows the actual price of the goods described.
                                </div>
                            </td>
                            <td width="45%" class="text-center" style="vertical-align:bottom; height:80px;">
                                For <strong><t t-esc="o.company_id.name"/></strong><br/><br/>
                                Authorised Signatory
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
