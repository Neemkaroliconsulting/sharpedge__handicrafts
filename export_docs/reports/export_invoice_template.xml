<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================= PAPER FORMAT ================= -->
    <record id="paperformat_export_a4" model="report.paperformat">
        <field name="name">Export Invoice A4 Clean</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">15</field>
        <field name="margin_bottom">15</field>
        <field name="margin_left">15</field>
        <field name="margin_right">15</field>
    </record>

    <!-- ================= REPORT ACTION ================= -->
    <record id="action_export_invoice_report" model="ir.actions.report">
        <field name="name">Export Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.export_invoice_template</field>
        <field name="report_file">export_docs.export_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <!-- ================= TEMPLATE ================= -->
<template id="export_invoice_template">
    <t t-call="web.basic_layout">
        <t t-foreach="docs" t-as="o">

            <div class="page">
                <h2>EXPORT INVOICE</h2>

                <!-- DEBUG -->
                <div>Invoice: <t t-esc="o.name"/></div>
                <div>Total Lines: <t t-esc="len(o.invoice_line_ids)"/></div>

                <table class="table table-bordered" style="width:100%;">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Price</th>
                        </tr>
                    </thead>

                    <tbody>

                        <!-- 🔥 DIRECT LOOP -->
                        <t t-foreach="o.invoice_line_ids" t-as="line">

                            <t t-if="line.product_id and not line.display_type">

                                <tr>
                                    <td><t t-esc="line.name"/></td>
                                    <td><t t-esc="line.quantity"/></td>
                                    <td><t t-esc="line.price_unit"/></td>
                                </tr>

                            </t>

                        </t>

                    </tbody>
                </table>

            </div>

        </t>
    </t>
</template>
</odoo>
