<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_tax_invoice_report" model="ir.actions.report">
        <field name="name">Tax Invoice (Export)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.tax_invoice_template</field>
        <field name="report_file">export_docs.tax_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="tax_invoice_template" t-name="export_docs.tax_invoice_template">
        <t t-call="web.basic_layout">
            <link rel="stylesheet" href="/export_docs/static/css/tax_style.css"/>
            <t t-foreach="docs" t-as="o">
                
                <t t-set="is_lut" t-value="o.fiscal_position_id and o.fiscal_position_id.name == 'Export - LUT (WOP)'"/>
                <t t-set="wiz" t-value="o._context.get('wizard_data', {})" />

                <t t-set="inv_currency" t-value="o.currency_id" />
                <t t-set="hsn_summary" t-value="o.get_export_hsn_summary()" />
                <t t-set="comp_currency" t-value="o.company_id.currency_id" />

                <t t-set="inv_to_comp_rate"
                    t-value="inv_currency._get_conversion_rate(inv_currency, comp_currency, o.company_id, o.invoice_date or o.date) or 0.0" />

                <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service')" />
                <t t-set="freight_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service' and 'freight' in (l.product_id.name or '').lower())" />
                <t t-set="insurance_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service' and 'insurance' in (l.product_id.name or '').lower())" />

                <t t-set="goods_total" t-value="sum(product_lines.mapped('price_subtotal'))" />
                <t t-set="freight_total" t-value="sum(freight_lines.mapped('price_subtotal'))" />
                <t t-set="insurance_total" t-value="sum(insurance_lines.mapped('price_subtotal'))" />

                <t t-set="gst_amount" t-value="sum(o.invoice_line_ids.filtered(lambda l: l.product_id and not (l.product_id.type != 'service' and is_lut)).mapped(lambda l: l.price_subtotal * (l.tax_ids and l.tax_ids[0].amount or 0) / 100))" />
                <t t-set="total_igst" t-value="gst_amount * inv_to_comp_rate" />
                
                <div class="page">
                    <style> 
                        table { width: 100%; border-collapse: collapse; font-size: 11.5px; font-family: "Times New Roman", serif; } 
                        td, th { border: 1px solid #000; padding: 2px 3px; vertical-align: top; }
                        .blank-row td { border-left: 1px solid #000; border-right: 1px solid #000; border-top: none; border-bottom: none; height: 16px; }
                        table.hsn-table td, table.hsn-table th { border: none; padding: 3px 5px; } 
                        table.hsn-table th { background: #f2f2f2; font-weight: bold; }
                    </style>

                    <h3 class="text-center" style="text-align:center;">TAX INVOICE</h3>

                    <table>
                        <tr>
                            <td width="50%">
                                <strong>Exporter: <t t-esc="o.company_id.name" /></strong><br/>
                                <t t-esc="o.company_id.street" />, <t t-esc="o.company_id.city" /><br/>
                                <strong>GSTIN:</strong> <t t-esc="o.company_id.vat" />
                            </td>
                            <td width="50%">
                                <strong>Invoice No:</strong> <t t-esc="o.name" /><br/>
                                <strong>Date:</strong> <t t-esc="o.invoice_date" />
                            </td>
                        </tr>
                    </table>

                    <table style="width:100%; margin-top:10px;">
                        <thead>
                            <tr style="background:#f2f2f2;">
                                <th>Sr</th>
                                <th>Description of Goods</th>
                                <th>HSN</th>
                                <th>Qty</th>
                                <th>Rate</th>
                                <th>Amount (<t t-esc="inv_currency.name" />)</th>
                                <th>GST %</th>
                                <th>GST Amt (INR)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sr" t-value="1" />
                            <t t-foreach="o.invoice_line_ids" t-as="line">
                                <t t-if="line.show_in_invoice">
                                    <tr>
                                        <td align="center"><t t-esc="sr" /></td>
                                        <td><t t-esc="line.name" /></td>
                                        <td align="center"><t t-esc="line.product_id.l10n_in_hsn_code" /></td>
                                        <td align="right"><t t-esc="line.quantity" /></td>
                                        <td align="right"><t t-esc="line.price_unit" /></td>
                                        <td align="right"><t t-esc="line.price_subtotal" /></td>
                                        <td align="right">
                                            <t t-if="line.product_id.type != 'service' and is_lut">0.0</t>
                                            <t t-else=""><t t-esc="line.tax_ids[0].amount if line.tax_ids else 0"/></t>
                                        </td>
                                        <td align="right">
                                            <t t-if="line.product_id.type != 'service' and is_lut">0.00</t>
                                            <t t-else=""><t t-esc="round((line.price_subtotal * (line.tax_ids[0].amount / 100 if line.tax_ids else 0)) * inv_to_comp_rate, 2)"/></t>
                                        </td>
                                    </tr>
                                    <t t-set="sr" t-value="sr + 1" />
                                </t>
                            </t>
                            <tr style="font-weight:bold; background:#f2f2f2;">
                                <td colspan="5" align="right">TOTAL</td>
                                <td align="right"><t t-esc="inv_currency.format(sum(o.invoice_line_ids.mapped('price_subtotal')))" /></td>
                                <td></td>
                                <td align="right"><t t-esc="comp_currency.format(total_igst)" /></td>
                            </tr>
                        </tbody>
                    </table>

                    <table style="width:100%; margin-top:5px;">
                        <tr>
                            <td width="60%">
                                <t t-if="is_lut">
                                    <strong>LUT Declaration:</strong> Supply meant for export under LUT without payment of integrated tax.
                                </t>
                            </td>
                            <td width="40%" style="padding:0;">
                                <table style="width:100%; border:none;">
                                    <tr><td>IGST (INR)</td><td align="right"><t t-esc="comp_currency.format(total_igst)"/></td></tr>
                                    <tr><td>Freight (<t t-esc="inv_currency.name"/>)</td><td align="right"><t t-esc="inv_currency.format(freight_total)"/></td></tr>
                                    <tr style="font-weight:bold; background:#eee;"><td>GRAND TOTAL</td><td align="right"><t t-esc="o.currency_id.format(o.amount_total)"/></td></tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <table style="width:100%; margin-top:10px; border: 1px solid black;">
                        <tr style="background:#f2f2f2; font-weight:bold;">
                            <td style="border:1px solid black;">HSN CODE</td>
                            <td style="border:1px solid black;">Taxable Value</td>
                            <td style="border:1px solid black;">IGST %</td>
                            <td style="border:1px solid black;">Tax Amt</td>
                        </tr>
                        <t t-foreach="hsn_summary" t-as="l">
                            <tr>
                                <td style="border:1px solid black;"><t t-esc="l['hsn']" /></td>
                                <td style="border:1px solid black;"><t t-esc="comp_currency.format(l['taxable'] * inv_to_comp_rate)" /></td>
                                <td style="border:1px solid black;">
                                    <t t-if="is_lut and l['hsn'] != '9965'">0.0</t>
                                    <t t-else=""><t t-esc="l['rate']" /></t>
                                </td>
                                <td style="border:1px solid black;">
                                    <t t-if="is_lut and l['hsn'] != '9965'">₹ 0.00</t>
                                    <t t-else=""><t t-esc="comp_currency.format((l['taxable'] * l['rate'] / 100) * inv_to_comp_rate)" /></t>
                                </td>
                            </tr>
                        </t>
                    </table>

                    <table style="width:100%; margin-top:10px; border:none;">
                        <tr>
                            <td style="border:none;"><strong>DECLARATION:</strong> We declare that this invoice shows the actual price.</td>
                            <td style="border:none; text-align:center;">For <strong><t t-esc="o.company_id.name"/></strong><br/><br/>Authorised Signatory</td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
