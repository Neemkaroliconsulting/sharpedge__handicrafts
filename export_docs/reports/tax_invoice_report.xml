<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_tax_invoice_report" model="ir.actions.report">
        <field name="name">Tax Invoice (Export)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.tax_invoice_template</field>
        <field name="report_file">export_docs.tax_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="tax_invoice_template" t-name="export_docs.tax_invoice_template">
        <t t-call="web.basic_layout">
            <link rel="stylesheet" href="/export_docs/static/css/tax_style.css"/>
            <t t-foreach="docs" t-as="o">

                <t t-set="wiz" t-value="o._context.get('wizard_data', {})" />
                <t t-set="inv_currency" t-value="o.currency_id" />
                <t t-set="hsn_summary" t-value="o.get_export_hsn_summary()" />
                <t t-set="comp_currency" t-value="o.company_id.currency_id" />

                <t t-set="inv_to_comp_rate"
                    t-value="inv_currency._get_conversion_rate(
                            inv_currency,
                            comp_currency,
                            o.company_id,
                            o.invoice_date or o.date
                    ) or 0.0" />

                <t t-set="insurance_lines"
                    t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service' and 'insurance' in (l.product_id.name or '').lower())" />

                <t t-set="product_lines"
                    t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service')" />

                <t t-set="freight_lines"
                    t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service' and 'freight' in (l.product_id.name or '').lower())" />

                <t t-set="goods_total" t-value="sum(product_lines.mapped('price_subtotal'))" />

                <t t-set="total_igst" t-value="sum((l.price_total - l.price_subtotal) * inv_to_comp_rate for l in o.invoice_line_ids)" />

                <t t-set="discount_amount" t-value="sum(((l.quantity * l.price_unit) * (l.discount or 0) / 100) for l in product_lines)" />

                <t t-set="freight_total" t-value="sum(freight_lines.mapped('price_subtotal'))" />

                <t t-set="insurance_total" t-value="sum(insurance_lines.mapped('price_subtotal'))" />

                <t t-set="net_cf" t-value="goods_total + freight_total" />
                <t t-set="net_cif_inv" t-value="net_cf + insurance_total - (discount_amount / (inv_to_comp_rate or 1) if discount_amount else 0)" />
                <t t-set="net_amount_incl_gst" t-value="(net_cif_inv * inv_to_comp_rate) + total_igst" />

                <div class="page">
                    <style> 
                        thead { display: table-header-group; } tr { page-break-inside: avoid; }
                        table { width: 100%; border-collapse: collapse; font-size: 11.5px; font-family: "Times New Roman", serif; } 
                        td, th { border: 1px solid #000; padding: 2px 3px; vertical-align: top; line-height: 1.2; }
                        .blank-row td { border-left: 1px solid #000; border-right: 1px solid #000; border-top: none; border-bottom: none; height: 16px; }
                        table.hsn-table td, table.hsn-table th { border: none; padding: 3px 5px; }
                    </style>

                    <h3 class="text-center" style="margin:0; text-align:center;">TAX INVOICE</h3>

                    <t t-set="buyer_orders" t-value="[]" />
                    <t t-foreach="o.invoice_line_ids" t-as="l">
                        <t t-foreach="l.sale_line_ids" t-as="sl">
                            <t t-if="sl.order_id and sl.order_id.buyer_order_no and sl.order_id.buyer_order_no not in buyer_orders">
                                <t t-set="buyer_orders" t-value="buyer_orders + [sl.order_id.buyer_order_no]" />
                            </t>
                        </t>
                    </t>

                    <table>
                        <tr>
                            <td width="50%">
                                <table width="100%" style="border:none;">
                                    <tr>
                                        <td width="25%" style="border:none;">
                                            <strong>Exporter</strong><br/>
                                            <t t-if="o.company_id.logo"><img t-att-src="image_data_uri(o.company_id.logo)" style="max-height:40px; max-width:70px;" /></t>
                                        </td>
                                        <td width="75%" style="border:none;">
                                            <strong><t t-esc="o.company_id.name" /></strong><br/>
                                            <t t-esc="o.company_id.street" /> <t t-esc="o.company_id.city" /><br/>
                                            <t t-esc="o.company_id.country_id.name" /><br/>
                                            <strong>GSTIN:</strong> <t t-esc="o.company_id.vat" />
                                        </td>
                                    </tr>
                                </table>
                            </td>
                            <td width="50%">
                                <strong>Invoice No:</strong> <t t-esc="o.name" /><br/>
                                <strong>Date:</strong> <t t-esc="o.invoice_date" /><br/>
                                <strong>Exporter Ref:</strong> <t t-esc="o.exporter_reference" /><br/>
                                <strong>Buyer Order No:</strong> <t t-esc="' / '.join(buyer_orders)" />
                            </td>
                        </tr>
                        <tr>
                            <td width="50%"><strong>Consignee</strong><br/><strong><t t-esc="o.consignee_id.name" /></strong><br/><t t-esc="o.consignee_id.street" /> <t t-esc="o.consignee_id.city" /></td>
                            <td width="50%"><strong>Buyer (if other than consignee)</strong><br/><t t-esc="o.buyer_id.name" /></td>
                        </tr>
                    </table>

                    <table style="width:100%; border-top:none;" class="item-table">
                        <thead>
                            <tr style="background:#f2f2f2;">
                                <th width="4%">Sr</th>
                                <th width="14%">Item Ref</th>
                                <th width="22%">Description of Goods</th>
                                <th width="8%">HSN</th>
                                <th width="8%">Qty</th>
                                <th width="8%">Rate</th>
                                <th width="10%">Amount (<t t-esc="inv_currency.name" />)</th>
                                <th width="10%">Taxable (INR)</th>
                                <th width="6%">GST%</th>
                                <th width="10%">GST (INR)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sr" t-value="1" />
                            <t t-foreach="o.invoice_line_ids" t-as="line">
                                <t t-if="line.show_in_invoice">
                                    <tr>
                                        <td align="center"><t t-esc="sr" /></td>
                                        <td><t t-esc="line.product_id.default_code" /></td>
                                        <td><t t-esc="line.name" /></td>
                                        <td align="right"><t t-esc="line.product_id.l10n_in_hsn_code" /></td>
                                        <td align="right"><t t-esc="line.quantity" /></td>
                                        <td align="right"><t t-esc="line.price_unit" t-options='{"widget": "float", "precision": 2}' /></td>
                                        <td align="right"><t t-esc="line.price_subtotal" t-options='{"widget": "float", "precision": 2}' /></td>
                                        <td align="right"><t t-esc="line.price_subtotal * inv_to_comp_rate" t-options='{"widget": "float", "precision": 2}' /></td>
                                        <td align="center">
                                            <t t-if="line.product_id.type != 'service' and o.fiscal_position_id.name == 'Export - LUT (WOP)'">0.0</t>
                                            <t t-else=""><t t-esc="line.tax_ids[0].amount if line.tax_ids else 0" /></t>
                                        </td>
                                        <td align="right">
                                            <t t-esc="(line.price_total - line.price_subtotal) * inv_to_comp_rate" t-options='{"widget": "float", "precision": 2}' />
                                        </td>
                                    </tr>
                                    <t t-set="sr" t-value="sr + 1" />
                                </t>
                            </t>
                            <t t-foreach="range(5)" t-as="i"><tr class="blank-row"><td colspan="10"></td></tr></t>
                            <tr style="font-weight:bold; background:#f2f2f2;">
                                <td colspan="6" align="right">TOTAL</td>
                                <td align="right"><t t-esc="inv_currency.format(sum(o.invoice_line_ids.mapped('price_subtotal')))" /></td>
                                <td align="right"><t t-esc="comp_currency.format(sum(o.invoice_line_ids.mapped('price_subtotal')) * inv_to_comp_rate)" /></td>
                                <td></td>
                                <td align="right"><t t-esc="comp_currency.format(total_igst)" /></td>
                            </tr>
                        </tbody>
                    </table>

                    <table style="width:100%; border-top:none;">
                        <tr>
                            <td width="50%" style="padding:10px;">
                                <strong>Amount Chargeable (In Words)</strong><br/>
                                <em><t t-esc="inv_currency.name"/> <t t-esc="inv_currency.amount_to_text(o.amount_total)"/> Only</em>
                                <br/><br/>
                                <t t-if="o.fiscal_position_id.name == 'Export - LUT (WOP)'">
                                    <strong>LUT Declaration:</strong> Supply meant for export under LUT without payment of IGST.
                                </t>
                            </td>
                            <td width="50%" style="padding:0;">
                                <table style="width:100%; border:none;">
                                    <tr><td style="border:none; border-bottom:1px solid #000; padding:4px;">IGST (INR)</td><td align="right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="comp_currency.format(total_igst)"/></td></tr>
                                    <tr><td style="border:none; border-bottom:1px solid #000; padding:4px;">Freight (<t t-esc="inv_currency.name"/>)</td><td align="right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(freight_total)"/></td></tr>
                                    <tr><td style="border:none; border-bottom:1px solid #000; padding:4px;">Insurance (<t t-esc="inv_currency.name"/>)</td><td align="right" style="border:none; border-bottom:1px solid #000; border-left:1px solid #000;"><t t-esc="inv_currency.format(insurance_total)"/></td></tr>
                                    <tr style="font-weight:bold; background:#f2f2f2;">
                                        <td style="border:none;">NET AMOUNT (Incl. GST)</td>
                                        <td align="right" style="border:none; border-left:1px solid #000;"><t t-esc="comp_currency.format(net_amount_incl_gst)"/></td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" align="right">
                                <strong>Exchange Rate : 1 <t t-esc="inv_currency.name" /> = <t t-esc="round(inv_to_comp_rate, 4)" /> <t t-esc="comp_currency.name" /></strong>
                            </td>
                        </tr>
                    </table>

                    <table style="width:100%; border-top:none;">
                        <tr>
                            <td width="65%"><strong>DECLARATION:</strong><br/> We declare that this invoice shows the actual price of the goods described.</td>
                            <td width="35%" align="center"><strong>For <t t-esc="o.company_id.name" /></strong><br/><br/><br/>Authorised Signatory</td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
