<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_tax_invoice_report" model="ir.actions.report">
        <field name="name">Tax Invoice (Export)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.tax_invoice_template</field>
        <field name="report_file">export_docs.tax_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="tax_invoice_template" t-name="export_docs.tax_invoice_template">
        <t t-call="web.basic_layout">
            <link rel="stylesheet" href="/export_docs/static/css/tax_style.css"/>
            <t t-foreach="docs" t-as="o">

                <t t-set="wiz" t-value="o._context.get('wizard_data', {})" />
                
                <t t-set="inv_currency" t-value="o.currency_id" />
                <t t-set="comp_currency" t-value="o.company_id.currency_id" />
                <t t-set="hsn_summary" t-value="o.get_export_hsn_summary()" />

                <t t-set="inv_to_comp_rate"
                    t-value="inv_currency._get_conversion_rate(
                            inv_currency,
                            comp_currency,
                            o.company_id,
                            o.invoice_date or o.date
                    ) or 1.0" />

                <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service')" />
                <t t-set="freight_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and 'freight' in (l.product_id.name or '').lower())" />
                <t t-set="insurance_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and 'insurance' in (l.product_id.name or '').lower())" />

                <t t-set="goods_total" t-value="sum(product_lines.mapped('price_subtotal'))" />

                <t t-set="total_gst_inr" t-value="sum((l.price_total - l.price_subtotal) * inv_to_comp_rate for l in o.invoice_line_ids)" />

                <t t-set="freight_total" t-value="sum(freight_lines.mapped('price_subtotal'))" />
                <t t-set="insurance_total" t-value="sum(insurance_lines.mapped('price_subtotal'))" />
                <t t-set="discount_total" t-value="sum(((l.quantity * l.price_unit) * (l.discount or 0) / 100) for l in o.invoice_line_ids)" />

                <t t-set="net_cif_inv" t-value="goods_total + freight_total + insurance_total - discount_total" />
                <t t-set="total_payable_inr" t-value="(net_cif_inv * inv_to_comp_rate) + total_gst_inr" />

                <div class="page">
                    <style>
                        table { width: 100%; border-collapse: collapse; font-size: 11px; font-family: serif; }
                        td, th { border: 1px solid #000; padding: 4px; vertical-align: top; }
                        .text-center { text-align: center; }
                        .text-right { text-align: right; }
                        .bg-light { background: #f2f2f2; font-weight: bold; }
                    </style>

                    <h3 class="text-center">TAX INVOICE (EXPORT)</h3>

                    <table>
                        <tr>
                            <td width="50%">
                                <strong>Exporter:</strong><br/>
                                <strong><t t-esc="o.company_id.name"/></strong><br/>
                                <t t-esc="o.company_id.street"/>, <t t-esc="o.company_id.city"/><br/>
                                GSTIN: <t t-esc="o.company_id.vat"/>
                            </td>
                            <td width="50%">
                                <strong>Invoice No:</strong> <t t-esc="o.name"/><br/>
                                <strong>Date:</strong> <t t-esc="o.invoice_date"/><br/>
                                <strong>Port of Loading:</strong> <t t-esc="o.port_loading"/>
                            </td>
                        </tr>
                    </table>

                    <table style="margin-top:10px;">
                        <thead class="bg-light">
                            <tr>
                                <th>Sr</th>
                                <th>Description</th>
                                <th>HSN</th>
                                <th>Qty</th>
                                <th>Rate</th>
                                <th>Amount (<t t-esc="inv_currency.name"/>)</th>
                                <th>Taxable (INR)</th>
                                <th>GST %</th>
                                <th>GST Amt (INR)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="sr" t-value="1"/>
                            <t t-foreach="product_lines" t-as="line">
                                <tr>
                                    <td class="text-center"><t t-esc="sr"/></td>
                                    <td><t t-esc="line.name"/></td>
                                    <td class="text-center"><t t-esc="line.product_id.l10n_in_hsn_code"/></td>
                                    <td class="text-right"><t t-esc="line.quantity"/></td>
                                    <td class="text-right"><t t-esc="line.price_unit" t-options='{"widget": "monetary", "display_currency": inv_currency}'/></td>
                                    <td class="text-right"><t t-esc="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": inv_currency}'/></td>
                                    <td class="text-right"><t t-esc="line.price_subtotal * inv_to_comp_rate" t-options='{"widget": "monetary", "display_currency": comp_currency}'/></td>
                                    <td class="text-center"><t t-esc="line.tax_ids[0].amount if line.tax_ids else 0"/>%</td>
                                    <td class="text-right">
                                        <t t-esc="(line.price_total - line.price_subtotal) * inv_to_comp_rate" t-options='{"widget": "monetary", "display_currency": comp_currency}'/>
                                    </td>
                                </tr>
                                <t t-set="sr" t-value="sr + 1"/>
                            </t>
                        </tbody>
                    </table>

                    <table style="margin-top:10px;">
                        <tr>
                            <td width="60%">
                                <strong>Amount in Words:</strong><br/>
                                <t t-esc="inv_currency.name"/> <t t-esc="inv_currency.amount_to_text(net_cif_inv)"/><br/><br/>
                                
                                <t t-if="o.fiscal_position_id.name == 'Export - LUT (WOP)'">
                                    <div style="border: 1px solid black; padding: 5px;">
                                        <strong>LUT Declaration:</strong> Supply meant for export under Letter of Undertaking (LUT) without payment of integrated tax.
                                    </div>
                                </t>
                            </td>
                            <td width="40%">
                                <table>
                                    <tr><td>Goods Total (<t t-esc="inv_currency.name"/>)</td><td class="text-right"><t t-esc="goods_total"/></td></tr>
                                    <tr><td>Freight (<t t-esc="inv_currency.name"/>)</td><td class="text-right"><t t-esc="freight_total"/></td></tr>
                                    <tr><td>Insurance (<t t-esc="inv_currency.name"/>)</td><td class="text-right"><t t-esc="insurance_total"/></td></tr>
                                    <tr class="bg-light"><td>Total GST (INR)</td><td class="text-right"><t t-esc="total_gst_inr"/></td></tr>
                                    <tr class="bg-light"><td><strong>Grand Total (INR)</strong></td><td class="text-right"><strong><t t-esc="total_payable_inr"/></strong></td></tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <table style="margin-top:20px; border:none;">
                        <tr style="border:none;">
                            <td style="border:none;">
                                <strong>Declaration:</strong><br/>
                                We declare that this invoice shows the actual price of the goods described and that all particulars are true and correct.
                            </td>
                            <td class="text-center" style="border:none;">
                                For <strong><t t-esc="o.company_id.name"/></strong><br/><br/><br/>
                                Authorised Signatory
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
