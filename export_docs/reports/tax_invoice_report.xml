<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<record id="action_tax_invoice_report" model="ir.actions.report">
    <field name="name">Tax Invoice (Export)</field>
    <field name="model">account.move</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">export_docs.tax_invoice_template</field>
    <field name="report_file">export_docs.tax_invoice_template</field>
    <field name="binding_model_id" ref="account.model_account_move" />
    <field name="binding_type">report</field>
    <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
</record>

<template id="tax_invoice_template" t-name="export_docs.tax_invoice_template">
    <t t-call="web.basic_layout">
        <link rel="stylesheet" href="/export_docs/static/css/tax_style.css"/>
        <t t-foreach="docs" t-as="o">

            <!-- 🔥 LUT DETECTION -->
            <t t-set="is_lut"
               t-value="o.fiscal_position_id and o.fiscal_position_id.name == 'Export - LUT (WOP)'"/>

            <t t-set="wiz" t-value="o._context.get('wizard_data', {})" />
            <t t-set="inv_currency" t-value="o.currency_id" />
            <t t-set="hsn_summary" t-value="o.get_export_hsn_summary()" />
            <t t-set="comp_currency" t-value="o.company_id.currency_id" />

            <t t-set="inv_to_comp_rate"
                t-value="inv_currency._get_conversion_rate(
                    inv_currency, comp_currency,
                    o.company_id, o.invoice_date or o.date
                ) or 0.0" />

            <!-- ================= LINES ================= -->
            <t t-set="product_lines"
                t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service')" />

            <!-- GOODS TOTAL -->
            <t t-set="goods_total" t-value="sum(product_lines.mapped('price_subtotal'))" />

            <!-- GST AMOUNT FIXED -->
            <t t-set="gst_amount"
                t-value="
                    sum(
                        o.invoice_line_ids.filtered(
                            lambda l: l.product_id and not (
                                l.product_id.type != 'service' and is_lut
                            )
                        ).mapped(
                            lambda l:
                                l.price_subtotal
                                * (l.tax_ids and l.tax_ids[0].amount or 0)
                                / 100
                        )
                    )
                " />

            <t t-set="net_amount_incl_gst"
                t-value="round((goods_total + gst_amount) * inv_to_comp_rate, 2)" />

            <div class="page">

                <!-- 🔥 CSS FIX -->
                <style>
                    table { width:100%; table-layout:fixed; border-collapse:collapse; }
                    td, th { border:1px solid #000; padding:4px; word-wrap:break-word; }
                </style>

                <h3 style="text-align:center;">TAX INVOICE</h3>

                <!-- ================= TABLE ================= -->
                <table class="item-table">
                    <thead>
                        <tr>
                            <th width="3%">Sr</th>
                            <th width="12%">Item Ref</th>
                            <th width="20%">Description</th>
                            <th width="7%">HSN</th>
                            <th width="7%">Qty</th>
                            <th width="7%">Rate</th>
                            <th width="10%">Amount</th>
                            <th width="10%">Taxable</th>
                            <th width="6%">GST%</th>
                            <th width="18%">GST Amt</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-set="sr" t-value="1"/>
                        <t t-set="total_amount" t-value="0.0"/>
                        <t t-set="total_taxable" t-value="0.0"/>
                        <t t-set="total_igst" t-value="0.0"/>

                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <t t-if="line.product_id">
                                <tr>
                                    <td><t t-esc="sr"/></td>
                                    <td><t t-esc="line.product_id.default_code"/></td>
                                    <td><t t-esc="line.name"/></td>
                                    <td><t t-esc="line.product_id.l10n_in_hsn_code"/></td>
                                    <td><t t-esc="line.quantity"/></td>
                                    <td><t t-esc="round(line.price_unit,2)"/></td>

                                    <td><t t-esc="round(line.price_subtotal,2)"/></td>

                                    <td>
                                        <t t-esc="round(line.price_subtotal * inv_to_comp_rate,2)"/>
                                    </td>

                                    <!-- GST % -->
                                    <td>
                                        <t t-esc="
                                            (line.product_id.type != 'service' and is_lut)
                                            and 0.0
                                            or (line.tax_ids and line.tax_ids[0].amount or 0)
                                        "/>
                                    </td>

                                    <!-- GST AMOUNT -->
                                    <td>
                                        <t t-esc="
                                            (line.product_id.type != 'service' and is_lut)
                                            and 0.0
                                            or round(
                                                (line.price_subtotal
                                                * (line.tax_ids and line.tax_ids[0].amount or 0) / 100)
                                                * inv_to_comp_rate, 2
                                            )
                                        "/>
                                    </td>

                                    <!-- TOTALS -->
                                    <t t-set="total_amount"
                                        t-value="total_amount + line.price_subtotal"/>

                                    <t t-set="total_taxable"
                                        t-value="total_taxable + (line.price_subtotal * inv_to_comp_rate)"/>

                                    <t t-set="total_igst"
                                        t-value="total_igst + (
                                            (line.product_id.type != 'service' and is_lut)
                                            and 0.0
                                            or (
                                                (line.price_subtotal
                                                * (line.tax_ids and line.tax_ids[0].amount or 0) / 100)
                                                * inv_to_comp_rate
                                            )
                                        )"/>
                                </tr>

                                <t t-set="sr" t-value="sr + 1"/>
                            </t>
                        </t>

                        <!-- TOTAL -->
                        <tr style="font-weight:bold;">
                            <td colspan="6">TOTAL</td>
                            <td><t t-esc="round(total_amount,2)"/></td>
                            <td><t t-esc="round(total_taxable,2)"/></td>
                            <td></td>
                            <td><t t-esc="round(total_igst,2)"/></td>
                        </tr>
                    </tbody>
                </table>

                <!-- ================= HSN FIX ================= -->
                <table>
                    <tr>
                        <th>HSN</th>
                        <th>Taxable</th>
                        <th>GST</th>
                    </tr>

                    <t t-foreach="hsn_summary" t-as="l">
                        <tr>
                            <td><t t-esc="l['hsn']"/></td>
                            <td><t t-esc="l['taxable'] * inv_to_comp_rate"/></td>
                            <td>
                                <t t-esc="
                                    (is_lut and 0.0)
                                    or ((l['taxable'] * l['rate'] / 100) * inv_to_comp_rate)
                                "/>
                            </td>
                        </tr>
                    </t>
                </table>

                <!-- ================= NET ================= -->
                <table>
                    <tr>
                        <td><strong>NET AMOUNT (Incl. GST)</strong></td>
                        <td align="right">
                            <t t-esc="net_amount_incl_gst"/>
                        </td>
                    </tr>
                </table>

            </div>

        </t>
    </t>
</template>
</odoo>
