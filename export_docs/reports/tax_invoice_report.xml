<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_tax_invoice_report" model="ir.actions.report">
        <field name="name">Tax Invoice (Export)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">export_docs.tax_invoice_template</field>
        <field name="report_file">export_docs.tax_invoice_template</field>
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="export_docs.paperformat_export_a4" />
    </record>

    <template id="tax_invoice_template" t-name="export_docs.tax_invoice_template">
        <t t-call="web.basic_layout">
            <link rel="stylesheet" href="/export_docs/static/css/tax_style.css"/>
            <t t-foreach="docs" t-as="o">

                <t t-set="inv_currency" t-value="o.currency_id" />
                <t t-set="comp_currency" t-value="o.company_id.currency_id" />
                <t t-set="inv_to_comp_rate" t-value="inv_currency._get_conversion_rate(inv_currency, comp_currency, o.company_id, o.invoice_date or o.date) or 1.0" />

                <t t-set="product_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type != 'service')" />
                <t t-set="service_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id and l.product_id.type == 'service')" />

                <t t-set="total_igst_inr" t-value="sum((l.price_total - l.price_subtotal) * inv_to_comp_rate for l in o.invoice_line_ids)" />

                <div class="page">
                    <style>
                        table { width: 100%; border-collapse: collapse; font-family: "Times New Roman", serif; font-size: 11px; }
                        th, td { border: 1px solid black; padding: 4px; vertical-align: top; }
                        .text-right { text-align: right; }
                        .text-center { text-align: center; }
                        .bg-light { background-color: #f2f2f2; font-weight: bold; }
                        .blank-row { height: 20px; }
                    </style>

                    <h3 class="text-center">TAX INVOICE</h3>

                    <table>
                        <tr>
                            <td width="50%">
                                <strong>Exporter</strong><br/>
                                <strong><t t-esc="o.company_id.name"/></strong><br/>
                                <t t-esc="o.company_id.street"/>, <t t-esc="o.company_id.city"/><br/>
                                <strong>GSTIN:</strong> <t t-esc="o.company_id.vat"/>
                            </td>
                            <td width="50%">
                                <strong>Invoice No:</strong> <t t-esc="o.name"/><br/>
                                <strong>Date:</strong> <t t-esc="o.invoice_date"/><br/>
                                <strong>Buyer Order No:</strong> <t t-esc="o.buyer_order_no or ''"/>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Consignee</strong><br/><t t-esc="o.consignee_id.name"/><br/><t t-esc="o.consignee_id.street"/></td>
                            <td><strong>Buyer (if other than consignee)</strong><br/><t t-esc="o.buyer_id.name"/></td>
                        </tr>
                    </table>

                    <table style="border-top: none;">
                        <tr class="bg-light text-center">
                            <td width="5%">Sr</td>
                            <td width="35%">Description of Goods &amp; Services</td>
                            <td width="10%">HSN</td>
                            <td width="10%">Qty</td>
                            <td width="10%">Rate</td>
                            <td width="15%">Amount (<t t-esc="inv_currency.name"/>)</td>
                            <td width="15%">GST (INR)</td>
                        </tr>
                        
                        <t t-set="sr" t-value="1"/>
                        <t t-foreach="product_lines" t-as="line">
                            <tr>
                                <td class="text-center"><t t-esc="sr"/></td>
                                <td><t t-esc="line.name"/></td>
                                <td class="text-center"><t t-esc="line.product_id.l10n_in_hsn_code"/></td>
                                <td class="text-right"><t t-esc="line.quantity"/></td>
                                <td class="text-right"><t t-esc="line.price_unit" t-options='{"widget": "float", "precision": 2}'/></td>
                                <td class="text-right"><t t-esc="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/></td>
                                <td class="text-right">0.00</td>
                            </tr>
                            <t t-set="sr" t-value="sr + 1"/>
                        </t>

                        <t t-foreach="service_lines" t-as="line">
                            <tr>
                                <td class="text-center"><t t-esc="sr"/></td>
                                <td><strong><t t-esc="line.name"/></strong></td>
                                <td class="text-center"><t t-esc="line.product_id.l10n_in_hsn_code"/></td>
                                <td class="text-right">1.0</td>
                                <td class="text-right"><t t-esc="line.price_unit" t-options='{"widget": "float", "precision": 2}'/></td>
                                <td class="text-right"><t t-esc="line.price_subtotal" t-options='{"widget": "float", "precision": 2}'/></td>
                                <td class="text-right">
                                    <t t-esc="(line.price_total - line.price_subtotal) * inv_to_comp_rate" t-options='{"widget": "float", "precision": 2}'/>
                                </td>
                            </tr>
                            <t t-set="sr" t-value="sr + 1"/>
                        </t>

                        <tr class="blank-row"><td colspan="7"></td></tr>
                    </table>

                    <table>
                        <tr>
                            <td width="60%" style="border-top: none;">
                                <strong>Amount in Words:</strong><br/>
                                <em><t t-esc="inv_currency.name"/> <t t-esc="inv_currency.amount_to_text(o.amount_total)"/> Only</em>
                                <br/><br/>
                                <t t-if="o.fiscal_position_id.name == 'Export - LUT (WOP)'">
                                    <strong>LUT Declaration:</strong> Supply meant for export under LUT without payment of integrated tax.
                                </t>
                            </td>
                            <td width="40%" style="padding:0; border-top: none;">
                                <table style="width:100%; border:none;">
                                    <tr>
                                        <td style="border:none; border-bottom:1px solid black; padding:4px;">IGST Payable (INR)</td>
                                        <td style="border:none; border-bottom:1px solid black; border-left:1px solid black;" class="text-right">
                                            <t t-esc="total_igst_inr" t-options='{"widget": "float", "precision": 2}'/>
                                        </td>
                                    </tr>
                                    <tr class="bg-light">
                                        <td style="border:none; padding:4px;">GRAND TOTAL</td>
                                        <td style="border:none; border-left:1px solid black;" class="text-right">
                                            <t t-esc="o.amount_total" t-options='{"widget": "monetary", "display_currency": inv_currency}'/>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>

                    <table style="border-top: none; margin-top: 5px;">
                        <tr>
                            <td width="65%">
                                <strong>DECLARATION:</strong><br/>
                                We declare that this invoice shows the actual price of the goods described.
                            </td>
                            <td width="35%" class="text-center">
                                For <strong><t t-esc="o.company_id.name"/></strong><br/><br/><br/>
                                Authorised Signatory
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
