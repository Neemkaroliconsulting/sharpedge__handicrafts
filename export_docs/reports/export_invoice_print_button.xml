<odoo>
    <record id="view_invoice_export_print" model="ir.ui.view">
        <field name="name">export.invoice.print</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_print_pdf']" position="after">
                <button name="action_open_export_print_wizard"
                        string="Print Custom Reports"
                        type="object"
                        class="btn btn-primary"
                        invisible="state != 'posted' or move_type not in ('out_invoice','out_refund')"/>
            </xpath>

        </field>
    </record>
</odoo>
