<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_product_form_export_fields" model="ir.ui.view">
        <field name="name">product.template.export.fields.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='inventory']" position="inside">

                <group string="Export Details" col="4">
                    <field name="x_export_item_ref"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
